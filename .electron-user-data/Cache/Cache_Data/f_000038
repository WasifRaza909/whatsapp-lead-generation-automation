,238,0.45), 0 0 80px rgba(34,211,238,0.12);\r\n}\n.btn-danger {\r\n  background: linear-gradient(135deg, var(--red) 0%, #dc2626 100%);\r\n  color: #fff;\r\n  animation: dangerPulse 3s var(--ease-in-out-smooth) infinite;\r\n}\n.btn-danger:hover { transform: translateY(-3px); }\n@keyframes dangerPulse {\r\n  0%, 100% { box-shadow: 0 4px 18px rgba(248,113,113,0.25); }\r\n  50%      { box-shadow: 0 4px 36px rgba(248,113,113,0.55); }\r\n}\n.btn-ghost {\r\n  background: rgba(255,255,255,0.03);\r\n  color: var(--text-dim);\r\n  border: 1px solid rgba(100,116,139,0.22);\r\n  transition: transform 0.45s var(--spring),\r\n              box-shadow 0.45s var(--ease-out-expo),\r\n              background 0.35s, color 0.35s, border-color 0.35s;\r\n}\n.btn-ghost:hover {\r\n  background: rgba(255,255,255,0.06);\r\n  color: #94a3b8;\r\n  border-color: rgba(148,163,184,0.3);\r\n  transform: translateY(-2px);\r\n}\n/* ── Reset button ───────────────────────────────────────────────────────── */\n.btn-reset {\r\n  background: linear-gradient(135deg, rgba(251,146,60,0.15) 0%, rgba(251,146,60,0.08) 100%);\r\n  color: #fb923c;\r\n  border: 1px solid rgba(251,146,60,0.35);\r\n  position: relative;\r\n  overflow: hidden;\r\n  transition: transform 0.45s var(--spring),\r\n              box-shadow 0.45s var(--ease-out-expo),\r\n              background 0.35s, color 0.35s, border-color 0.35s;\r\n}\n.btn-reset:hover:not(:disabled) {\r\n  background: linear-gradient(135deg, rgba(251,146,60,0.28) 0%, rgba(251,146,60,0.18) 100%);\r\n  color: #fdba74;\r\n  border-color: rgba(251,146,60,0.65);\r\n  box-shadow: 0 0 20px rgba(251,146,60,0.25);\r\n  transform: translateY(-3px);\r\n}\nbutton:disabled {\r\n  opacity: 0.3;\r\n  cursor: not-allowed;\r\n  transform: none !important;\r\n  box-shadow: none !important;\r\n  animation: none !important;\r\n}\n/* ── Scan indicator (status line when not running) ──────────────────────── */\n@keyframes fadeSoft {\r\n  from { opacity: 0; transform: translateY(6px); }\r\n  to   { opacity: 1; transform: translateY(0); }\r\n}\n.scan-indicator {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.7rem;\r\n  margin-top: 0.9rem;\r\n  animation: fadeSoft 0.6s var(--ease-out-expo);\r\n}\n.scan-text {\r\n  font-size: 0.82rem;\r\n  font-weight: 600;\r\n  color: var(--cyan);\r\n  transition: color 0.4s;\r\n}\n.scan-text.err { color: var(--red); }\n.scan-text.ok  { color: var(--green); }\n/* ── Professional Scraping Loader (standalone section, outside form-card) ── */\n.scrape-loader {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 1.6rem;\r\n  margin-bottom: 1.5rem;\r\n  padding: 1.4rem 1.8rem;\r\n  background: rgba(34,211,238,0.05);\r\n  border: 1px solid rgba(34,211,238,0.18);\r\n  border-radius: 16px;\r\n  animation: fadeSoft 0.4s var(--ease-out-expo) both;\r\n  position: relative;\r\n  overflow: hidden;\r\n}\n/* subtle shimmer sweep */\n.scrape-loader::before {\r\n  content: '';\r\n  position: absolute;\r\n  inset: 0;\r\n  background: linear-gradient(105deg, transparent 30%, rgba(34,211,238,0.04) 50%, transparent 70%);\r\n  animation: loaderSheen 3s linear infinite;\r\n}\n@keyframes loaderSheen {\r\n  0%   { transform: translateX(-100%); }\r\n  100% { transform: translateX(200%); }\r\n}\n/* Radar visual */\n.scrape-loader__radar {\r\n  position: relative;\r\n  width: 40px;\r\n  height: 40px;\r\n  flex-shrink: 0;\r\n  /* Extra space so rings can expand beyond the 56px core */\r\n  overflow: visible;\r\n}\n.scrape-loader__ring {\r\n  position: absolute;\r\n  inset: 0;\r\n  border: 1.5px solid var(--cyan);\r\n  border-radius: 50%;\r\n  will-change: transform, opacity;\r\n  animation: radarRing 2.6s var(--ease-out-quart) infinite;\r\n}\n.scrape-loader__ring:nth-child(2) { animation-delay: 0.87s; }\n.scrape-loader__ring:nth-child(3) { animation-delay: 1.74s; }\n@keyframes radarRing {\r\n  0%   { transform: scale(0.15); opacity: 0.9; }\r\n  70%  { opacity: 0.15; }\r\n  100% { transform: scale(1.85); opacity: 0; }\r\n}\n.scrape-loader__core {\r\n  position: absolute;\r\n  top: 50%; left: 50%;\r\n  transform: translate(-50%, -50%);\r\n  width: 13px;\r\n  height: 13px;\r\n  border-radius: 50%;\r\n  background: var(--cyan);\r\n  box-shadow: 0 0 14px var(--cyan), 0 0 28px rgba(34,211,238,0.45);\r\n  animation: coreBeat 1.9s var(--ease-in-out-smooth) infinite;\r\n}\n@keyframes coreBeat {\r\n  0%, 100% { transform: translate(-50%,-50%) scale(1);   box-shadow: 0 0 14px var(--cyan); }\r\n  50%       { transform: translate(-50%,-50%) scale(1.25); box-shadow: 0 0 22px var(--cyan), 0 0 44px rgba(34,211,238,0.5); }\r\n}\n/* Loader text body */\n.scrape-loader__body {\r\n  flex: 1;\r\n  min-width: 0;\r\n}\n.scrape-loader__header {\r\n  display: flex;\r\n  align-items: baseline;\r\n  justify-content: space-between;\r\n  gap: 0.5rem;\r\n  margin-bottom: 0.4rem;\r\n}\n.scrape-loader__title {\r\n  font-size: 0.68rem;\r\n  font-weight: 800;\r\n  color: var(--cyan);\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.13em;\r\n}\n.scrape-loader__count {\r\n  display: flex;\r\n  align-items: baseline;\r\n  gap: 0.25rem;\r\n}\n.scrape-loader__count-val {\r\n  font-size: 1.25rem;\r\n  font-weight: 900;\r\n  color: var(--cyan);\r\n  font-variant-numeric: tabular-nums;\r\n  line-height: 1;\r\n  transition: color 0.3s;\r\n  text-shadow: 0 0 16px rgba(34,211,238,0.4);\r\n}\n.scrape-loader__count-label {\r\n  font-size: 0.62rem;\r\n  font-weight: 700;\r\n  color: var(--text-dim);\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.09em;\r\n}\n.scrape-loader__status {\r\n  font-size: 0.83rem;\r\n  font-weight: 500;\r\n  color: var(--text);\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  margin-bottom: 0.65rem;\r\n  min-height: 1.2em;\r\n  transition: opacity 0.25s;\r\n}\n.scrape-loader__bar {\r\n  height: 3px;\r\n  background: rgba(51,65,85,0.4);\r\n  border-radius: 999px;\r\n  overflow: hidden;\r\n  position: relative;\r\n}\n.scrape-loader__bar-fill {\r\n  position: absolute;\r\n  top: 0; left: 0;\r\n  height: 100%;\r\n  width: 38%;\r\n  border-radius: 999px;\r\n  background: linear-gradient(90deg, transparent, var(--cyan) 30%, var(--purple) 55%, var(--cyan) 80%, transparent);\r\n  box-shadow: 0 0 14px rgba(34,211,238,0.65), 0 0 36px rgba(34,211,238,0.2);\r\n  will-change: transform;\r\n  animation: scanBar 2.8s var(--ease-in-out-smooth) infinite;\r\n}\n@keyframes scanBar {\r\n  0%   { transform: translateX(-160%); opacity: 0.35; }\r\n  15%  { opacity: 1; }\r\n  85%  { opacity: 1; }\r\n  100% { transform: translateX(430%);  opacity: 0.35; }\r\n}\n/* ── Table section ──────────────────────────────────────────────────────── */\n.table-wrap {\r\n  animation: fadeUp 0.7s var(--ease-out-expo) both;\r\n}\n@keyframes fadeUp {\r\n  from { opacity: 0; transform: translateY(20px); }\r\n  to   { opacity: 1; transform: translateY(0);    }\r\n}\n.table-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: 1.1rem;\r\n}\n.table-title {\r\n  font-size: 0.65rem;\r\n  font-weight: 800;\r\n  color: var(--text-dim);\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.14em;\r\n}\n.leads-badge {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: rgba(34,211,238,0.1);\r\n  color: var(--cyan);\r\n  font-weight: 800;\r\n  font-size: 0.78rem;\r\n  font-variant-numeric: tabular-nums;\r\n  padding: 0.18rem 0.65rem;\r\n  border-radius: 999px;\r\n  border: 1px solid rgba(34,211,238,0.25);\r\n  box-shadow: 0 0 12px rgba(34,211,238,0.15);\r\n  transition: transform 0.5s var(--spring);\r\n}\n.table-outer {\r\n  background: var(--surface);\r\n  border: 1px solid rgba(30,41,59,0.75);\r\n  border-radius: 16px;\r\n  overflow: hidden;\r\n  backdrop-filter: blur(16px);\r\n}\ntable {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  font-size: 0.83rem;\r\n}\nthead { position: sticky; top: 0; z-index: 2; }\nth {\r\n  background: rgba(3,9,18,0.95);\r\n  padding: 0.75rem 1rem;\r\n  text-align: left;\r\n  color: var(--text-dim);\r\n  font-weight: 800;\r\n  text-transform: uppercase;\r\n  font-size: 0.6rem;\r\n  letter-spacing: 0.12em;\r\n  border-bottom: 1px solid rgba(30,41,59,0.7);\r\n}\n/* Sortable column header button + indicator */\n.th-btn {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 0.45rem;\r\n  background: transparent;\r\n  border: none;\r\n  color: var(--text-dim);\r\n  cursor: pointer;\r\n  font-weight: 800;\r\n  font-size: 0.6rem;\r\n  padding: 0;\r\n}\n.th-btn.active { color: var(--cyan); }\n.th-btn:hover { color: var(--text); }\n.sort-indicator {\r\n  width: 12px;\r\n  height: 12px;\r\n  display: inline-block;\r\n  position: relative;\r\n}\n.sort-indicator::before,\r\n.sort-indicator::after {\r\n  content: '';\r\n  position: absolute;\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  border-left: 5px solid transparent;\r\n  border-right: 5px solid transparent;\r\n  width: 0;\r\n}\n.sort-indicator::before { bottom: 6px; border-bottom: 6px solid var(--text-dim); opacity: 0.45; transition: opacity 0.18s; }\n.sort-indicator::after  { top: 6px;    border-top:    6px solid var(--text-dim); opacity: 0.25; transition: opacity 0.18s; }\n.sort-indicator.asc::before  { border-bottom-color: var(--cyan); opacity: 1; }\n.sort-indicator.desc::after  { border-top-color: var(--cyan);    opacity: 1; }\n/* th-btn inherits uppercase/letter-spacing from th; keep text-transform */\n.th-label { text-transform: uppercase; letter-spacing: 0.12em; }\n/* ── AI error banner ─────────────────────────────────────────────────────── */\n.ai-error-banner {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.6rem;\r\n  margin-bottom: 0.9rem;\r\n  padding: 0.7rem 1rem;\r\n  background: rgba(248,113,113,0.08);\r\n  border: 1px solid rgba(248,113,113,0.28);\r\n  border-radius: 10px;\r\n  animation: fadeSoft 0.4s var(--ease-out-expo);\r\n}\n.ai-error-icon { font-size: 0.9rem; }\n.ai-error-msg {\r\n  flex: 1;\r\n  font-size: 0.82rem;\r\n  font-weight: 600;\r\n  color: #fca5a5;\r\n  line-height: 1.45;\r\n}\n.ai-error-close {\r\n  background: transparent;\r\n  border: none;\r\n  color: #f87171;\r\n  font-size: 0.72rem;\r\n  padding: 0.2rem 0.4rem;\r\n  cursor: pointer;\r\n  border-radius: 5px;\r\n  flex-shrink: 0;\r\n}\n.ai-error-close:hover { background: rgba(248,113,113,0.12); }\n.ai-error-close::after { display: none; }\ntd {\r\n  padding: 0.72rem 1rem;\r\n  border-bottom: 1px solid rgba(9,18,33,0.7);\r\n  vertical-align: middle;\r\n  color: #64748b;\r\n  transition: background 0.35s var(--ease-out-expo),\r\n              color 0.35s;\r\n}\ntr:last-child td { border-bottom: none; }\ntr:hover td {\r\n  background: rgba(34,211,238,0.03);\r\n}\n/* ── New row entrance ───────────────────────────────────────────────────── */\n.row-new td {\r\n  animation: rowEntrance 0.8s var(--ease-out-expo);\r\n}\n@keyframes rowEntrance {\r\n  0%   { opacity: 0; transform: translateX(-12px); background: rgba(34,211,238,0.16); }\r\n  40%  { background: rgba(34,211,238,0.08); }\r\n  100% { opacity: 1; transform: translateX(0);    background: transparent; }\r\n}\n/* ── Cell variants ──────────────────────────────────────────────────────── */\n.td-num {\r\n  color: var(--text-mute);\r\n  width: 48px;\r\n  text-align: right;\r\n  font-weight: 700;\r\n  font-size: 0.74rem;\r\n  font-variant-numeric: tabular-nums;\r\n}\n.td-name {\r\n  color: var(--text);\r\n  font-weight: 600;\r\n}\n.td-phone {\r\n  color: var(--cyan);\r\n  font-family: 'JetBrains Mono', 'Cascadia Code', 'Fira Code', 'Consolas', monospace;\r\n  font-size: 0.8rem;\r\n  font-weight: 500;\r\n}\n.td-email {\r\n  max-width: 180px;\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  font-size: 0.8rem;\r\n}\n.td-addr {\r\n  max-width: 200px;\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  font-size: 0.8rem;\r\n}\n.muted { color: var(--text-mute); }\na {\r\n  color: var(--cyan);\r\n  text-decoration: none;\r\n  transition: color 0.35s, text-decoration-color 0.35s;\r\n  text-decoration: underline transparent;\r\n}\na:hover {\r\n  color: #67e8f9;\r\n  text-decoration-color: #67e8f9;\r\n}\n/* ── View button ─────────────────────────────────────────────────────────── */\n.btn-view {\r\n  background: rgba(34,211,238,0.07);\r\n  color: var(--cyan);\r\n  border: 1px solid rgba(34,211,238,0.2);\r\n  padding: 0.28rem 0.52rem;\r\n  font-size: 0.78rem;\r\n  cursor: pointer;\r\n  border-radius: 7px;\r\n  will-change: transform;\r\n  transition: color 0.3s, background 0.3s, border-color 0.3s, box-shadow 0.3s,\r\n              transform 0.35s var(--spring);\r\n}\n.btn-view:hover {\r\n  background: rgba(34,211,238,0.16);\r\n  border-color: rgba(34,211,238,0.45);\r\n  box-shadow: 0 0 14px rgba(34,211,238,0.2);\r\n  transform: scale(1.15) !important;\r\n  animation: none !important;\r\n}\n.btn-view::after { display: none; }\n/* ── Lead Detail Modal ───────────────────────────────────────────────────── */\n.modal-overlay {\r\n  position: fixed;\r\n  inset: 0;\r\n  z-index: 100;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  padding: 1rem;\r\n  background: rgba(3,9,18,0.82);\r\n  backdrop-filter: blur(10px);\r\n  -webkit-backdrop-filter: blur(10px);\r\n  animation: fadeSoft 0.22s var(--ease-out-expo) both;\r\n}\n.modal-card {\r\n  background: rgba(9,18,33,0.96);\r\n  border: 1px solid rgba(51,65,85,0.65);\r\n  border-radius: 22px;\r\n  width: 100%;\r\n  max-width: 520px;\r\n  box-shadow: 0 32px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(34,211,238,0.06);\r\n  animation: modalPop 0.35s var(--ease-out-expo) both;\r\n  overflow: hidden;\r\n  position: relative;\r\n}\n/* top accent line */\n.modal-card::before {\r\n  content: '';\r\n  position: absolute;\r\n  top: 0; left: 0; right: 0;\r\n  height: 1px;\r\n  background: linear-gradient(90deg, transparent 10%, var(--cyan) 50%, transparent 90%);\r\n  opacity: 0.45;\r\n}\n@keyframes modalPop {\r\n  from { opacity: 0; transform: scale(0.92) translateY(20px); }\r\n  to   { opacity: 1; transform: scale(1)    translateY(0);     }\r\n}\n.modal-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  padding: 1.4rem 1.6rem 1.1rem;\r\n  border-bottom: 1px solid rgba(30,41,59,0.6);\r\n}\n.modal-title-group {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.85rem;\r\n  min-width: 0;\r\n}\n.modal-icon { font-size: 1.5rem; flex-shrink: 0; }\n.modal-title {\r\n  font-size: 1.05rem;\r\n  font-weight: 800;\r\n  color: var(--text);\r\n  letter-spacing: -0.02em;\r\n  line-height: 1.2;\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n}\n.modal-subtitle {\r\n  font-size: 0.67rem;\r\n  font-weight: 700;\r\n  color: var(--text-dim);\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.1em;\r\n  display: block;\r\n  margin-top: 0.15rem;\r\n}\n.modal-close {\r\n  background: rgba(255,255,255,0.04);\r\n  border: 1px solid rgba(100,116,139,0.2);\r\n  color: var(--text-dim);\r\n  width: 32px; height: 32px;\r\n  border-radius: 8px;\r\n  display: flex; align-items: center; justify-content: center;\r\n  font-size: 0.8rem;\r\n  cursor: pointer;\r\n  flex-shrink: 0;\r\n  transition: color 0.25s, background 0.25s, border-color 0.25s, transform 0.3s var(--spring);\r\n}\n.modal-close:hover {\r\n  color: var(--text);\r\n  background: rgba(248,113,113,0.1);\r\n  border-color: rgba(248,113,113,0.3);\r\n  transform: scale(1.1) !important;\r\n}\n.modal-close::after { display: none; }\n.modal-body {\r\n  padding: 1.2rem 1.6rem 1.5rem;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 0.85rem;\r\n}\n.modal-field {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 0.3rem;\r\n}\n.modal-field__label {\r\n  font-size: 0.62rem;\r\n  font-weight: 800;\r\n  color: var(--text-dim);\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.12em;\r\n}\n.modal-field__value {\r\n  font-size: 0.9rem;\r\n  color: var(--text);\r\n  font-weight: 500;\r\n  line-height: 1.5;\r\n  word-break: break-word;\r\n}\n.modal-field--ai {\r\n  margin-top: 0.3rem;\r\n  padding-top: 1rem;\r\n  border-top: 1px solid rgba(30,41,59,0.55);\r\n}\n.modal-ai-msg {\r\n  font-size: 0.88rem;\r\n  color: #c4b5fd;\r\n  line-height: 1.6;\r\n  background: rgba(167,139,250,0.06);\r\n  border: 1px solid rgba(167,139,250,0.15);\r\n  border-radius: 10px;\r\n  padding: 0.75rem 1rem;\r\n  margin: 0;\r\n  font-weight: 500;\r\n}\n@media (max-width: 600px) {\r\n  .modal-card { border-radius: 16px; }\r\n  .modal-header, .modal-body { padding-left: 1.1rem; padding-right: 1.1rem; }\r\n}\n/* ── Delete button ──────────────────────────────────────────────────────── */\n.btn-del {\r\n  background: transparent;\r\n  color: var(--text-mute);\r\n  border: 1px solid transparent;\r\n  padding: 0.3rem 0.6rem;\r\n  font-size: 0.76rem;\r\n  cursor: pointer;\r\n  border-radius: 7px;\r\n  will-change: transform;\r\n  transition: color 0.35s var(--ease-out-expo),\r\n              background 0.35s var(--ease-out-expo),\r\n              border-color 0.35s,\r\n              transform 0.45s var(--spring);\r\n}\n.btn-del:hover {\r\n  color: var(--red);\r\n  background: rgba(248,113,113,0.08);\r\n  border-color: rgba(248,113,113,0.25);\r\n  transform: scale(1.2) !important;\r\n  box-shadow: none !important;\r\n  animation: none !important;\r\n}\n.btn-del::after { display: none; }\n/* ── Per-row Generate AI message button ─────────────────────────────────── */\n.td-actions {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.3rem;\r\n  white-space: nowrap;\r\n}\n.btn-gen-one {\r\n  background: rgba(167,139,250,0.1);\r\n  color: #a78bfa;\r\n  border: 1px solid rgba(167,139,250,0.28);\r\n  padding: 0.28rem 0.55rem;\r\n  font-size: 0.78rem;\r\n  cursor: pointer;\r\n  border-radius: 7px;\r\n  will-change: transform;\r\n  transition: color 0.3s var(--ease-out-expo),\r\n              background 0.3s var(--ease-out-expo),\r\n              border-color 0.3s,\r\n              box-shadow 0.3s,\r\n              transform 0.4s var(--spring);\r\n}\n.btn-gen-one:hover {\r\n  background: rgba(167,139,250,0.22);\r\n  color: #c4b5fd;\r\n  border-color: rgba(167,139,250,0.5);\r\n  box-shadow: 0 0 14px rgba(167,139,250,0.25);\r\n  transform: scale(1.15) !important;\r\n  animation: none !important;\r\n}\n.btn-gen-one::after { display: none; }\n.btn-gen-one.btn-regen {\r\n  background: rgba(34,211,238,0.08);\r\n  color: #22d3ee;\r\n  border-color: rgba(34,211,238,0.25);\r\n  font-size: 0.85rem;\r\n}\n.btn-gen-one.btn-regen:hover {\r\n  background: rgba(34,211,238,0.2);\r\n  color: #67e8f9;\r\n  border-color: rgba(34,211,238,0.5);\r\n  box-shadow: 0 0 14px rgba(34,211,238,0.25);\r\n}\n/* Generating state inside cell */\n.ai-generating {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 0.4rem;\r\n}\n.ai-generating-label {\r\n  font-size: 0.72rem;\r\n  color: #a78bfa;\r\n  font-style: italic;\r\n}\n/* ── Scrollbar ──────────────────────────────────────────────────────────── */\n::-webkit-scrollbar { width: 6px; }\n::-webkit-scrollbar-track { background: transparent; }\n::-webkit-scrollbar-thumb {\r\n  background: rgba(51,65,85,0.5);\r\n  border-radius: 999px;\r\n}\n::-webkit-scrollbar-thumb:hover { background: rgba(51,65,85,0.8); }\n/* ── Selection ──────────────────────────────────────────────────────────── */\n::selection {\r\n  background: rgba(34,211,238,0.25);\r\n  color: #fff;\r\n}\n/* ═══════════════════════════════════════════════════════════════════════════\r\n   Tab Navigation\r\n   ═══════════════════════════════════════════════════════════════════════════ */\n.tab-nav {\r\n  display: flex;\r\n  gap: 0.4rem;\r\n  margin-bottom: 1.8rem;\r\n  background: rgba(9,18,33,0.6);\r\n  border: 1px solid var(--border);\r\n  border-radius: 12px;\r\n  padding: 0.35rem;\r\n  width: fit-content;\r\n}\n.tab-btn {\r\n  position: relative;\r\n  background: transparent;\r\n  color: var(--text-dim);\r\n  border: none;\r\n  padding: 0.55rem 1.3rem;\r\n  font-size: 0.84rem;\r\n  font-weight: 700;\r\n  border-radius: 9px;\r\n  cursor: pointer;\r\n  letter-spacing: 0.02em;\r\n  transition: color 0.35s var(--ease-out-expo),\r\n              background 0.35s var(--ease-out-expo),\r\n              box-shadow 0.35s var(--ease-out-expo);\r\n}\n.tab-btn::after { display: none; }\n.tab-btn:hover { color: #94a3b8; background: rgba(255,255,255,0.04); }\n.tab-btn.active {\r\n  background: rgba(34,211,238,0.12);\r\n  color: var(--cyan);\r\n  box-shadow: inset 0 0 0 1px rgba(34,211,238,0.2);\r\n}\n/* red dot warning badge */\n.tab-alert {\r\n  position: absolute;\r\n  top: 6px; right: 8px;\r\n  width: 6px; height: 6px;\r\n  background: #f87171;\r\n  border-radius: 50%;\r\n  box-shadow: 0 0 6px rgba(248,113,113,0.7);\r\n  animation: breathe 2.8s var(--ease-in-out-smooth) infinite;\r\n}\n/* ── Table header actions row ───────────────────────────────────────────── */\n.table-actions {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.75rem;\r\n}\n/* ── Process with AI button ─────────────────────────────────────────────── */\n.btn-ai {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 0.45rem;\r\n  background: linear-gradient(135deg, rgba(167,139,250,0.18) 0%, rgba(34,211,238,0.12) 100%);\r\n  color: #c4b5fd;\r\n  border: 1px solid rgba(167,139,250,0.3);\r\n  padding: 0.45rem 1rem;\r\n  font-size: 0.8rem;\r\n  font-weight: 700;\r\n  border-radius: 8px;\r\n  cursor: pointer;\r\n  letter-spacing: 0.025em;\r\n  white-space: nowrap;\r\n  position: relative;\r\n  overflow: hidden;\r\n  will-change: transform;\r\n  transition:\r\n    transform 0.45s var(--spring),\r\n    box-shadow 0.45s var(--ease-out-expo),\r\n    background 0.35s,\r\n    color 0.35s,\r\n    border-color 0.35s;\r\n}\n.btn-ai::after { display: none; }\n.btn-ai:hover:not(:disabled) {\r\n  background: linear-gradient(135deg, rgba(167,139,250,0.28) 0%, rgba(34,211,238,0.2) 100%);\r\n  color: #ddd6fe;\r\n  border-color: rgba(167,139,250,0.5);\r\n  box-shadow: 0 0 24px rgba(167,139,250,0.25);\r\n  transform: translateY(-2px);\r\n}\n.btn-ai--warn {\r\n  color: #fbbf24;\r\n  border-color: rgba(251,191,36,0.3);\r\n  background: rgba(251,191,36,0.08);\r\n}\n.btn-ai--warn:hover:not(:disabled) {\r\n  background: rgba(251,191,36,0.14);\r\n  box-shadow: 0 0 20px rgba(251,191,36,0.2);\r\n}\n.btn-ai:disabled { opacity: 0.3; cursor: not-allowed; transform: none !important; }\n.btn-ai__badge {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: rgba(167,139,250,0.3);\r\n  color: #ede9fe;\r\n  font-size: 0.63rem;\r\n  font-weight: 800;\r\n  min-width: 18px;\r\n  height: 18px;\r\n  border-radius: 999px;\r\n  padding: 0 0.35rem;\r\n  margin-left: 0.1rem;\r\n}\n/* ── AI running pill ─────────────────────────────────────────────────────── */\n.ai-running-pill {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 0.5rem;\r\n  background: rgba(167,139,250,0.1);\r\n  border: 1px solid rgba(167,139,250,0.25);\r\n  border-radius: 8px;\r\n  padding: 0.42rem 0.9rem;\r\n  font-size: 0.78rem;\r\n  font-weight: 700;\r\n  color: #c4b5fd;\r\n  font-variant-numeric: tabular-nums;\r\n}\n.ai-running-dot {\r\n  width: 7px; height: 7px;\r\n  border-radius: 50%;\r\n  background: #a78bfa;\r\n  box-shadow: 0 0 8px #a78bfa;\r\n  animation: breathe 1.6s var(--ease-in-out-smooth) infinite;\r\n}\n.ai-running-pct {\r\n  margin-left: 0.2rem;\r\n  color: rgba(196,181,253,0.6);\r\n  font-size: 0.72rem;\r\n}\n/* ── AI stop button ─────────────────────────────────────────────────────── */\n.btn-ai-stop {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: 22px;\r\n  height: 22px;\r\n  margin-left: 0.5rem;\r\n  padding: 0;\r\n  border-radius: 6px;\r\n  border: 1px solid rgba(248,113,113,0.35);\r\n  background: rgba(248,113,113,0.1);\r\n  color: #f87171;\r\n  font-size: 0.7rem;\r\n  font-weight: 700;\r\n  cursor: pointer;\r\n  line-height: 1;\r\n  transition:\r\n    background 0.3s var(--ease-out-expo),\r\n    border-color 0.3s,\r\n    transform 0.35s var(--spring),\r\n    box-shadow 0.3s;\r\n}\n.btn-ai-stop::after { display: none; }\n.btn-ai-stop:hover {\r\n  background: rgba(248,113,113,0.22);\r\n  border-color: rgba(248,113,113,0.6);\r\n  box-shadow: 0 0 14px rgba(248,113,113,0.3);\r\n  transform: scale(1.15) !important;\r\n}\n.btn-ai-stop:active {\r\n  transform: scale(0.92) !important;\r\n}\n/* ── AI progress bar strip ──────────────────────────────────────────────── */\n.ai-progress-wrap {\r\n  margin-bottom: 0.9rem;\r\n  animation: fadeSoft 0.5s var(--ease-out-expo);\r\n}\n.ai-progress-track {\r\n  height: 3px;\r\n  background: rgba(51,65,85,0.3);\r\n  border-radius: 999px;\r\n  overflow: hidden;\r\n  margin-bottom: 0.45rem;\r\n}\n.ai-progress-fill {\r\n  height: 100%;\r\n  border-radius: 999px;\r\n  background: linear-gradient(90deg, #a78bfa, #22d3ee, #a78bfa);\r\n  background-size: 200% 100%;\r\n  box-shadow: 0 0 14px rgba(167,139,250,0.6);\r\n  transition: width 0.9s var(--ease-out-expo);\r\n  animation: gradShift 4s linear infinite;\r\n}\n.ai-progress-label {\r\n  font-size: 0.76rem;\r\n  color: #64748b;\r\n  font-style: italic;\r\n}\n.ai-progress-label strong { color: #c4b5fd; font-style: normal; }\n/* ── AI table cell ──────────────────────────────────────────────────────── */\n.td-ai {\r\n  max-width: 260px;\r\n}\n.ai-msg {\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n  font-size: 0.78rem;\r\n  color: #94a3b8;\r\n  line-height: 1.45;\r\n  cursor: help;\r\n  transition: color 0.3s;\r\n}\ntr:hover .ai-msg { color: #c4b5fd; }\n/* Three-dot pending animation */\n.ai-pending-dots {\r\n  display: inline-flex;\r\n  gap: 3px;\r\n  align-items: center;\r\n}\n.ai-pending-dots span {\r\n  display: inline-block;\r\n  width: 4px; height: 4px;\r\n  border-radius: 50%;\r\n  background: #a78bfa;\r\n  animation: dotBounce 1.4s var(--ease-in-out-smooth) infinite;\r\n}\n.ai-pending-dots span:nth-child(2) { animation-delay: 0.2s; }\n.ai-pending-dots span:nth-child(3) { animation-delay: 0.4s; }\n@keyframes dotBounce {\r\n  0%, 80%, 100% { transform: translateY(0);    opacity: 0.4; }\r\n  40%            { transform: translateY(-4px); opacity: 1;   }\r\n}\n/* ═══════════════════════════════════════════════════════════════════════════\r\n   Settings Page\r\n   ═══════════════════════════════════════════════════════════════════════════ */\n.settings-page {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 1.4rem;\r\n  animation: staggerIn 0.7s var(--ease-out-expo) both;\r\n}\n.settings-card {\r\n  background: var(--surface);\r\n  backdrop-filter: blur(22px);\r\n  -webkit-backdrop-filter: blur(22px);\r\n  border: 1px solid var(--border);\r\n  border-radius: 18px;\r\n  padding: 2rem 2.2rem;\r\n  position: relative;\r\n  overflow: hidden;\r\n  transition: border-color 0.5s var(--ease-out-expo);\r\n}\n.settings-card::before {\r\n  content: '';\r\n  position: absolute;\r\n  top: 0; left: 0; right: 0;\r\n  height: 1px;\r\n  background: linear-gradient(90deg, transparent, rgba(167,139,250,0.35) 50%, transparent);\r\n}\n.settings-card--dim {\r\n  background: rgba(9,18,33,0.4);\r\n  border-color: rgba(30,41,59,0.5);\r\n}\n.settings-card__header {\r\n  display: flex;\r\n  align-items: flex-start;\r\n  gap: 1rem;\r\n  margin-bottom: 1.5rem;\r\n}\n.settings-card__icon {\r\n  font-size: 2rem;\r\n  line-height: 1;\r\n  flex-shrink: 0;\r\n  margin-top: 0.1rem;\r\n}\n.settings-card__title {\r\n  font-size: 1.05rem;\r\n  font-weight: 800;\r\n  color: var(--text);\r\n  letter-spacing: -0.02em;\r\n  margin-bottom: 0.3rem;\r\n}\n.settings-card__sub {\r\n  font-size: 0.82rem;\r\n  color: var(--text-dim);\r\n  line-height: 1.5;\r\n}\n.settings-divider {\r\n  height: 1px;\r\n  background: var(--border);\r\n  margin-bottom: 1.4rem;\r\n  opacity: 0.5;\r\n}\n.settings-label {\r\n  display: block;\r\n  font-size: 0.63rem;\r\n  font-weight: 800;\r\n  color: var(--text-dim);\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.12em;\r\n  margin-bottom: 0.5rem;\r\n}\n.settings-hint {\r\n  font-size: 0.75rem;\r\n  color: var(--text-dim);\r\n  margin-top: 0.45rem;\r\n  margin-bottom: 1.2rem;\r\n  line-height: 1.5;\r\n}\n.settings-hint em {\r\n  color: #a78bfa;\r\n  font-style: normal;\r\n  font-weight: 600;\r\n}\n/* API key input wrapper */\n.key-input-wrap {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0;\r\n  margin-bottom: 1.2rem;\r\n  background: rgba(0,0,0,0.4);\r\n  border: 1px solid var(--border);\r\n  border-radius: 10px;\r\n  overflow: hidden;\r\n  transition: border-color 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);\r\n}\n.key-input-wrap:focus-within {\r\n  border-color: rgba(167,139,250,0.55);\r\n  box-shadow: 0 0 0 4px rgba(167,139,250,0.08), 0 0 24px rgba(167,139,250,0.06);\r\n}\n.key-input {\r\n  flex: 1;\r\n  background: transparent;\r\n  border: none;\r\n  color: var(--text);\r\n  font-size: 0.88rem;\r\n  font-weight: 500;\r\n  padding: 0.75rem 1rem;\r\n  outline: none;\r\n  font-family: 'JetBrains Mono', 'Cascadia Code', 'Fira Code', 'Consolas', monospace;\r\n  letter-spacing: 0.04em;\r\n}\n.key-toggle {\r\n  background: transparent;\r\n  border: none;\r\n  color: var(--text-dim);\r\n  padding: 0.7rem 0.9rem;\r\n  cursor: pointer;\r\n  font-size: 1rem;\r\n  border-left: 1px solid var(--border);\r\n  border-radius: 0;\r\n  transition: color 0.25s, background 0.25s;\r\n  flex-shrink: 0;\r\n}\n.key-toggle:hover { color: var(--text); background: rgba(255,255,255,0.04); }\n.key-toggle::after { display: none; }\n.key-toggle:active { transform: none !important; }\n.settings-actions {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.75rem;\r\n  flex-wrap: wrap;\r\n  margin-bottom: 0.9rem;\r\n}\n.btn-settings-validate {\r\n  background: rgba(255,255,255,0.04);\r\n  color: #94a3b8;\r\n  border: 1px solid rgba(